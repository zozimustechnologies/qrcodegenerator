{
    "manifest_version": 3,
    "name": "QR Code Generator",
    "version": "1.0.0",
    "description": "Instantly generate QR codes for any URL or text right from your browser sidebar. A fast, lightweight, and privacy-friendly QR code tool — no sign-up, no tracking, no ads.",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        },
        "default_title": "Open QR Code Generator"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "permissions": [
        "sidePanel"
    ],
    "background": {
        "service_worker": "background.js"
    }
}
